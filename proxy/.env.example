# ═══════════════════════════════════════════════════════════════
# DeepClaude — Provider Configuration (Example)
# ═══════════════════════════════════════════════════════════════
# Copy this to .env and fill in your API keys.
# Set API_PROVIDER to the provider you want to use.
# Just run: ./deepclaude.sh  (reads .env automatically)
#
# Supported providers: doubleword, nvidia, kimi, deepseek
# ═══════════════════════════════════════════════════════════════

API_PROVIDER=doubleword

# ───────────────────────────────────────────────────────────────
# DoubleWord AI  (OpenAI-compatible)
# URL: https://api.doubleword.ai/v1
# ───────────────────────────────────────────────────────────────
DOUBLEWORD_API_KEY=your-doubleword-api-key
DOUBLEWORD_MODEL=deepseek-ai/DeepSeek-V4-Pro

# ───────────────────────────────────────────────────────────────
# NVIDIA NIM  (OpenAI-compatible)
# URL: https://integrate.api.nvidia.com/v1
# ───────────────────────────────────────────────────────────────
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_MODEL=moonshotai/Kimi-K2.6

# ───────────────────────────────────────────────────────────────
# Kimi / Moonshot AI  (OpenAI-compatible)
# URL: https://api.moonshot.ai/v1
# Docs: https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# ───────────────────────────────────────────────────────────────
MOONSHOT_API_KEY=your-moonshot-api-key
KIMI_MODEL=kimi-k2.6

# ───────────────────────────────────────────────────────────────
# DeepSeek  (Native Anthropic format — no translation needed)
# URL: https://api.deepseek.com/anthropic
# ───────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro